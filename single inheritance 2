#include <iostream>

using namespace std;

class emp
{
public:
    string name;
    int empid;

    void details()
    {
        cout << "Enter the name: ";
        cin >> name;

        cout << "Enter the empid: ";
        cin >> empid;
    }
};

class salary : public emp
{
public:
    int payment;

    void annualamount()
    {
        cout << "Enter the basic pay: ";
        cin >> payment;
    }

    void display()
    {
        cout << "Empid: " << empid << endl;
        cout << "Name: " << name << endl;
        cout << "Annual Salary: " << payment * 12 << endl;
    }
};

int main()
{
    salary s;
    s.details();
    s.annualamount();
    s.display();


