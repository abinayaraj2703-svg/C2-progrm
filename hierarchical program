#include <iostream>

using namespace std;

class vehicle{
public:
    string brand;
    string model;

};

class car : public vehicle
{
public:
    int doors;

    void data()
    {
        cout << "Enter the car brand: ";
        cin >>  brand;
        cout << "Enter the car model: ";
        cin >>  model;
        cout << "Enter the number of doors: ";
        cin >>  doors;
    }

    void display()
    {
        cout << "Brand: " << brand << endl;
        cout << "Model: " << model << endl;
        cout << "Number of Doors: " << doors << endl;
    }
};

class bike : public vehicle
{
public:
    int capacity;

    void data()
    {
         cout << "Enter the bike brand: ";
        cin >> brand;
        cout << "Enter the bike  model: ";
        cin >>  model;
        cout << "Enter the engine capacity: ";
        cin >> capacity;
    }

    void display()
    {
        cout << "Brand: " << brand << endl;
        cout << "Model: " << model << endl;
        cout << "Engine Capacity: " << capacity << " cc" << endl;
    }
};

int main()
{
    car c;
    bike b;
    c.data();
    b.data();
    c.display();
    b.display();

    return 0;
}
